{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pi-agent",
  "version": "0.6.12",
  "identifier": "com.deermansayno.pi-agent",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:30141",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "placeholder-dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "resources/pi-agent-server.js": "pi-agent-server.js",
      "../.next/standalone": "app/standalone",
      "../.next/static": "app/standalone/.next/static",
      "../public": "app/standalone/public"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
