{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the main window",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://localhost:30141",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "dialog:allow-open"
  ]
}
